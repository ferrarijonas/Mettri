{
  "name": "mettri",
  "version": "2.0.1",
  "description": "Plataforma de vendas conversacionais para WhatsApp Web",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.js --watch",
    "build": "node esbuild.config.js",
    "construir": "node esbuild.config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "type-check": "tsc --noEmit",
    "check-mocks": "node .karma/scripts/check-mocks/index.mjs",
    "check-cleanup": "node .karma/scripts/check-cleanup/index.mjs",
    "test:coverage": "vitest run --coverage",
    "gate": "npm run check-mocks && npm run check-cleanup && npm run lint && npm run type-check && npm run build && npm run test:coverage",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:rag:browser": "node esbuild.config.js && playwright test tests/e2e/rag-fonte-real-db.spec.ts",
    "test:cdp": "tsx tests/automation/index.ts",
    "chrome:debug": "powershell -ExecutionPolicy Bypass -File scripts/build/start-chrome-debug.ps1",
    "package": "powershell -ExecutionPolicy Bypass -File scripts/build/package-extension.ps1",
    "build:modules": "node esbuild.config.js --modules-only",
    "publish-modules": "powershell -ExecutionPolicy Bypass -File scripts/build/publish-modules.ps1",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "whatsapp",
    "crm",
    "chrome-extension",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/chrome": "^0.0.260",
    "@types/node": "^25.0.6",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.23",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^5.0.2",
    "jsdom": "^24.1.3",
    "level": "^10.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.0",
    "puppeteer-core": "^24.34.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "puppeteer": "^25.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  }
}
