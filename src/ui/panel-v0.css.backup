/**
 * Estilos do Design v0 Premium
 * 
 * Baseado no design do v0 com glassmorphism, NavBar vertical e Sidebar.
 * Usa variáveis CSS do nosso sistema de temas.
 */

/* ============================================
   GLASSMORPHISM - Efeitos de vidro
   ============================================ */

.glass {
  background: var(--mettri-glass-bg, rgba(255, 255, 255, 0.65));
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid var(--mettri-glass-border, rgba(255, 255, 255, 0.3));
  box-shadow: 
    0 4px 30px var(--mettri-glass-shadow, rgba(0, 0, 0, 0.08)),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.glass-subtle {
  background: var(--mettri-glass-bg, rgba(255, 255, 255, 0.65));
  backdrop-filter: blur(12px) saturate(150%);
  -webkit-backdrop-filter: blur(12px) saturate(150%);
  border: 1px solid var(--mettri-glass-border, rgba(255, 255, 255, 0.3));
}

/* Dark mode glassmorphism */
#mettri-panel[data-theme="vscode-industrial"] .glass,
#mettri-panel[data-theme="vscode-industrial"] .glass-subtle {
  background: rgba(37, 37, 38, 0.75);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 
    0 4px 30px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

/* ============================================
   NAVBAR - Barra vertical direita
   ============================================ */

.mettri-navbar {
  position: fixed;
  top: 0;
  right: 0;
  width: 56px;
  height: 100vh;
  background: var(--mettri-accent, #1DAA61);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 0;
  gap: 4px;
  z-index: 10000;
  box-shadow: -2px 0 8px rgba(0, 0, 0, 0.1);
}

.mettri-navbar-divider {
  width: 32px;
  height: 1px;
  background: var(--mettri-text-on-accent, #FFFFFF);
  opacity: 0.2;
  margin: 4px 0;
}

.mettri-navbar-spacer {
  flex: 1;
}

.mettri-navbar-btn {
  width: 40px;
  height: 40px;
  background: none;
  border: none;
  border-radius: 12px;
  color: var(--mettri-text-on-accent, #FFFFFF);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  padding: 0;
}

.mettri-navbar-btn svg {
  width: 20px;
  height: 20px;
  pointer-events: none;
}

.mettri-navbar-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  color: var(--mettri-text-on-accent, #FFFFFF);
}

.mettri-navbar-btn.active {
  background: rgba(255, 255, 255, 0.2);
  color: var(--mettri-text-on-accent, #FFFFFF);
}

.mettri-navbar-module {
  opacity: 0.6;
}

.mettri-navbar-module:hover,
.mettri-navbar-module.active {
  opacity: 1;
}

/* ============================================
   SIDEBAR - Painel de conteúdo principal
   ============================================ */

.mettri-sidebar {
  position: fixed;
  top: 0;
  right: 56px; /* NavBar width */
  width: 300px;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--mettri-bg, #FFFFFF);
  color: var(--mettri-text, #0A1014);
  font-family: var(--wa-font-family, "Roboto Variable", "Segoe UI", "Helvetica Neue", Helvetica, "Lucida Grande", Arial, Ubuntu, Cantarell, "Fira Sans", sans-serif);
  z-index: 9999;
  box-shadow: -2px 0 8px rgba(0, 0, 0, 0.1);
  animation: slide-in-right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes slide-in-right {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* Sidebar Header */
.mettri-sidebar-header {
  height: 48px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--mettri-accent, #1DAA61);
  color: var(--mettri-text-on-accent, #FFFFFF);
}

.mettri-sidebar-header-title {
  display: flex;
  align-items: center;
  gap: 8px;
}

.mettri-sidebar-title-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--mettri-text-on-accent, #FFFFFF);
}

.mettri-sidebar-header-actions {
  display: flex;
  align-items: center;
  gap: 2px;
}

.mettri-kebab-menu,
.mettri-header-btn {
  width: 28px;
  height: 28px;
  background: none;
  border: none;
  border-radius: 8px;
  color: var(--mettri-text-on-accent, #FFFFFF);
  opacity: 0.7;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.mettri-kebab-menu svg,
.mettri-header-btn svg {
  width: 16px;
  height: 16px;
  pointer-events: none;
}

.mettri-kebab-menu:hover,
.mettri-header-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  opacity: 1;
}

/* Status Bar */
.mettri-status-bar {
  padding: 8px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--mettri-border, rgba(17, 27, 33, 0.1));
  border-bottom-opacity: 0.2;
}

.mettri-status-bar-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.mettri-status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--mettri-accent, #1DAA61);
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.mettri-status-dot.active {
  background: var(--mettri-success-color, #00A884);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.mettri-status-text {
  font-size: 11px;
  color: var(--mettri-text-secondary, #5B6368);
}

.mettri-refresh-btn {
  width: 24px;
  height: 24px;
  background: none;
  border: none;
  border-radius: 6px;
  color: var(--mettri-text-secondary, #5B6368);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.mettri-refresh-btn svg {
  width: 12px;
  height: 12px;
  pointer-events: none;
}

.mettri-refresh-btn:hover {
  background: var(--mettri-bg-secondary, #F7F5F3);
  color: var(--mettri-text, #0A1014);
}

/* Content Area */
.mettri-content {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Sidebar Footer */
.mettri-sidebar-footer {
  padding: 8px 16px;
  border-top: 1px solid var(--mettri-border, rgba(17, 27, 33, 0.1));
  border-top-opacity: 0.2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mettri-footer-text {
  font-size: 9px;
  color: var(--mettri-text-secondary, #5B6368);
  opacity: 0.6;
}

/* ============================================
   KEBAB MENU - Dropdown menu
   ============================================ */

.mettri-kebab-menu-container {
  position: relative;
}

.mettri-kebab-menu-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  min-width: 176px;
  background: var(--mettri-glass-bg, rgba(255, 255, 255, 0.65));
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid var(--mettri-glass-border, rgba(255, 255, 255, 0.3));
  border-radius: 12px;
  padding: 4px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
  z-index: 10001;
  display: none;
  animation: fade-in 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.mettri-kebab-menu-dropdown.show {
  display: block;
}

@keyframes fade-in {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(-4px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.mettri-kebab-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 12px;
  color: var(--mettri-text, #0A1014);
  cursor: pointer;
  background: none;
  border: none;
  width: 100%;
  text-align: left;
  transition: background 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.mettri-kebab-menu-item:hover,
.mettri-kebab-menu-item:focus {
  background: var(--mettri-accent, rgba(29, 170, 97, 0.15));
  outline: none;
}

.mettri-kebab-menu-item svg {
  width: 14px;
  height: 14px;
  color: var(--mettri-text-secondary, #5B6368);
  flex-shrink: 0;
}

.mettri-kebab-menu-item.destructive {
  color: var(--mettri-error-color, #EA0038);
}

.mettri-kebab-menu-item.destructive:hover {
  background: var(--mettri-error-bg, rgba(234, 0, 56, 0.1));
}

.mettri-kebab-menu-divider {
  height: 1px;
  background: var(--mettri-border, rgba(17, 27, 33, 0.1));
  margin: 4px 0;
  opacity: 0.3;
}
